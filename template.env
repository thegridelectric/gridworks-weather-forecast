# Copy to .env (gitignored) and fill in.
# Settings use GWWF_ prefix; nested fields use __ delimiter.

# Rabbit broker URL — amqp:// for non-TLS, amqps:// for TLS.
GWWF_RABBIT__URL=amqp://smqPublic:smqPublic@localhost:5672/d1__1

# g.node.gt JSON identity file — see wiki/gridworks-base for the schema.
GWWF_G_NODE_PATH=/Users/jessica/GridWorks/gridworks-weather-forecast/g_node.json

GWWF_LOG_LEVEL=INFO
